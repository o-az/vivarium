{
  "file_types": {
    "env": [".env", ".env.*"],
    "HTML": ["*.html", "*.svg"]
  },
  "hidden_files": ["**/.wrangler", "**/.tanstack", "**/.claude", ".DS_Store"],
  "file_scan_exclusions": [
    ".git",
    "**/.wrangler",
    "**/.vscode",
    "**/.tanstack",
    "**/.claude",
    "**/.cursor",
    ".DS_Store"
  ],
  "languages": {
    "CSS": {
      "language_servers": ["oxfmt", "css-language-server", "tailwindcss-language-server"],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "HTML": {
      "format_on_save": "on",
      "language_servers": ["oxfmt", "tailwindcss-language-server"],
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "MDX": {
      "language_servers": ["typescript-language-server", "oxfmt", "oxlint"],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        }
      ]
    },
    "Markdown": {
      "language_servers": ["typescript-language-server", "oxfmt", "oxlint", "markdown-oxide"],
      "format_on_save": "on",
      "prettier": {
